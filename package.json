{
  "name": "leezerd",
  "displayName": "Leezerd",
  "description": "Plays the lizard sound when you type 'l', 'L', or the word 'lizard'",
  "version": "1.0.0",
  "publisher": "inkfangs",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/gible717/leezerd.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "meme",
    "lizard",
    "sound",
    "fun"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Leezerd",
      "properties": {
        "leezerd.cooldownMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Minimum milliseconds between sound triggers. 0 = fires for every single character."
        },
        "leezerd.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the Leezerd sound."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  },
  "dependencies": {}
}
